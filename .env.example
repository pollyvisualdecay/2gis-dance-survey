# Environment variables for Dance Survey deployment
# Copy this file to .env and fill in your values

# Nginx configuration
NGINX_PORT=80
NGINX_SSL_PORT=443

# n8n configuration
N8N_HOST=localhost
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# n8n Basic Auth (optional but recommended)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-secure-password

# Telegram Bot (optional)
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Google Sheets (optional)
# Create service account and download JSON key
GOOGLE_CREDENTIALS=your-google-credentials-json
GOOGLE_SHEET_ID=your-google-sheet-id

# Database (if using PostgreSQL instead of SQLite)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=secure-password
POSTGRES_DB=n8n

# SSL Configuration (if using HTTPS)
# SSL_CERT_FILE=/etc/nginx/ssl/cert.pem
# SSL_KEY_FILE=/etc/nginx/ssl/key.pem

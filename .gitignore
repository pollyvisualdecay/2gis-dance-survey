logs/
*.log

# SSL certificates (keep the directory, exclude certs)
ssl/*.key
ssl/*.pem

# Temporary files
tmp/
temp/
*.tmp

# Build outputs
dist/
build/

# Video files (comment out if you want to track videos)
videos/*.mp4
videos/*.webm
videos/*.ogg

# Backup files
*.bak
*.backup

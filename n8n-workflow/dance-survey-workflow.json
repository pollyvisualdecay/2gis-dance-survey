{
  "name": "Dance Survey Form Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "dance-survey",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-node",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "dance-survey-webhook"
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "success",
              "value": "true"
            },
            {
              "name": "message",
              "value": "Данные успешно получены"
            }
          ]
        },
        "options": {}
      },
      "id": "respond-node",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "resource": "sheet",
        "path": "/dance-survey-answers.xlsx",
        "sheetName": "Ответы",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "timestamp": "={{ $now }}",
            "name": "={{ $json.name }}",
            "email": "={{ $json.email }}",
            "directions": "={{ $json.directions }}",
            "other_direction": "={{ $json.other_direction }}",
            "price": "={{ $json.price }}",
            "duration": "={{ $json.duration }}",
            "frequency": "={{ $json.frequency }}",
            "schedule": "={{ $json.schedule }}",
            "experience": "={{ $json.experience }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "id": "nextcloud-node",
      "name": "Nextcloud Save",
      "type": "n8n-nodes-base.nextcloud",
      "typeVersion": 2,
      "position": [550, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Respond to Webhook": {
      "main": [
        [
          {
            "node": "Nextcloud Save",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
